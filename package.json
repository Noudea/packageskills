{
  "name": "packageskills-workspace",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Noudea/packageskills.git"
  },
  "bugs": {
    "url": "https://github.com/Noudea/packageskills/issues"
  },
  "homepage": "https://github.com/Noudea/packageskills#readme",
  "engines": {
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "pnpm build && pnpm --filter @packageskills/tests test:run",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.13.10",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.57.1"
  }
}
