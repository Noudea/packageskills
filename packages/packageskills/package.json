  "version": "0.0.0",
  "description": "CLI for scaffolding and packaging agent skills.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Noudea/packageskills.git",
    "directory": "packages/packageskills"
  },
